---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Link from '../components/Link.astro';
import SectionContainer from './SectionContainer.astro';
import { SITE_TITLE, OWNER_NAME, POST_CODE, ADDRESS, TEL, FAX, GOOGLE_MAP_URL } from '../data/site';
import * as Lucide from 'lucide-astro';
import tarot11 from '../assets/images/tarot/tarot_majar_arcana_11.webp';
import tarot1 from '../assets/images/tarot/tarot_majar_arcana_1.webp';

const getIcon = (name: string) => {
  return Lucide[name as keyof typeof Lucide];
};

const footerData = (await getEntry('home', 'footer'))!;
// JSONからデータを抽出
const links = footerData.data.links || [];
const sublinks = footerData.data.sublinks || [];

// OWNER_NAME を埋め込む処理
const copyright = footerData.data.copyright.replace('{NAME}', SITE_TITLE);
---

<footer class="relative py-20 bg-main-1/70 border-t border-main-1/10">

  <div class="absolute bottom-40 -left-20 w-64 opacity-5 rotate-25 pointer-events-none grayscale">
    <Image src={tarot11} alt="" />
  </div>
  <div class="absolute bottom-10 left-30 w-64 opacity-5 rotate-9 pointer-events-none grayscale">
    <Image src={tarot1} alt="" />
  </div>

  <SectionContainer>
    <div class="grid md:grid-cols-[1fr_2fr] gap-16 mb-16">
      
      {/* 左側：サイト情報 */}
      <div class="space-y-8">
        <h2 class="text-2xl font-serif text-white-1 font-bold">{SITE_TITLE}</h2>
        <div class="space-y-3 text-base text-white-1 leading-relaxed">
          <p>〒{POST_CODE}<br />{ADDRESS}</p>
          <p>電話番号：{TEL}</p>
          <p>FAX：{FAX}</p>
        </div>

      </div>

      {/* 右側：リンクとマップ */}
      <div class="space-y-8">
        {/* メインリンク */}
        <nav>
          <ul class="flex flex-wrap gap-x-8 gap-y-4 list-none p-0 m-0">
      {links.map((link) => {
          const Icon = getIcon(link.icon);
          return (
            <Link href={link.url} class="flex items-center gap-2 text-base text-white-1 hover:text-accent-1 transition-colors">
              {Icon && <Icon class="w-4 h-4 text-white-1/50" />}
              <span>{link.name}</span>
            </Link>
          );
        })}
          </ul>
        </nav>
        
        {/* 地図 */}
        <div class="aspect-video w-[70%] rounded-2xl overflow-hidden shadow-sm border border-main-1/10">
          <iframe 
            src={GOOGLE_MAP_URL} 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy"
            title="事務所の場所"
          ></iframe>
        </div>
      </div>
    </div>

    {/* 下段：サブリンクとコピーライト */}
    <div class="pt-10 border-t border-main-1/5 space-y-8">

      <div class="flex flex-wrap justify-end gap-6 pt-4">
			<div class="flex items-center gap-8">
				{/* Twitter(X) */}
				<i class="fa-brands fa-x-twitter text-2xl text-white-1/60"></i>
				{/* Instagram */}
				<i class="fa-brands fa-instagram text-2xl text-white-1/60"></i>
				{/* LINE */}
				<i class="fa-brands fa-line text-2xl text-white-1/60"></i>
			</div>
        </div>
      
      <div>
      <ul class="flex flex-wrap justify-end gap-6 list-none p-0 m-0">
        {sublinks.map((link) => (
          <li>
            <Link href={link.url} class="text-base text-black-1/60 text-white-1 hover:text-white-1/50 transition-colors">
              {link.name}
            </Link>
          </li>
        ))}
      </ul>
      </div>

      <div>
      <p class="flex flex-wrap justify-end text-sm text-white-1/80">
        {copyright}
      </p>
      </div>
    </div>
  </SectionContainer>
</footer>