---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Link from '../components/Link.astro';
import heroImage from '../assets/images/hero.webp';

const heroData = (await getEntry('home', 'hero'))!;
const { heroTitle, heroSub, heroDescription, buttonText } = heroData.data;
---

<section class="relative w-full min-h-screen flex items-center justify-center px-6 py-20 md:py-40 bg-base-1 overflow-hidden">

  {/* 装飾コンテナ */}
  <div class="absolute inset-0 w-full h-full pointer-events-none">
    <div class="absolute -top-10 -left-10 w-80 h-80 bg-main-1/30 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-10 right-0 w-70 h-70 bg-accent-1/30 rounded-full blur-[100px]"></div>
  </div>

  {/* flex-col-reverse でモバイルは写真が上に、md以上で左写真・右テキストに */}
<div class="relative z-10 w-full max-w-[1200px] flex flex-col md:flex-row items-center gap-8 lg:gap-16">
    
    {/* 1. 写真エリア（先に記述することで、モバイルでは上に来る） */}
    <div class="flex-1 w-full relative px-4 md:px-0">
      <div class="hidden md:block absolute -top-3 -right-3 w-full h-full border border-main-1/20 rounded-3xl -z-10"></div>
      
      <Image 
        src={heroImage} 
        alt="占い風景" 
        class="rounded-3xl shadow-2xl w-full h-auto object-cover max-h-[500px] max-h-[50vh] aspect-[4/2] md:aspect-[4/3] lg:aspect-auto" 
      />
    </div>

    {/* 2. テキストエリア（後に記述することで、モバイルでは下に来る） */}
    <div class="flex-1 space-y-6 md:space-y-8 text-center md:text-left">
      <div class="space-y-4">
        <p class="text-main-1 font-serif tracking-widest uppercase text-sm md:text-base font-semibold">{heroSub}</p>
        <h1 class="text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-serif leading-[1.2] text-black-1" set:html={heroTitle} />
      </div>
      
      <div class="text-black-1/80 leading-relaxed mx-auto md:mx-0 text-left" set:html={heroDescription} />
      
      <div class="pt-4">
        <Link href="/contact" class="inline-flex items-center bg-main-1 text-white px-8 md:px-10 py-3 md:py-4 rounded-full shadow-lg hover:shadow-main-1/20 transition-all hover:-translate-y-1">
          {buttonText}
		</Link>
      </div>
    </div>
</div>
</section>