---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero.webp';

const heroData = (await getEntry('home', 'hero'))!;
const { heroTitle, heroSub, heroDescription, buttonText } = heroData.data;
---

<section class="relative flex flex-col md:flex-row items-center justify-center min-h-[calc(100vh-80px)] px-6 py-12 bg-base-1">
  
  {/* 装飾コンテナ */}
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-20 -left-20 w-96 h-96 bg-main-1 rounded-full opacity-30 blur-[100px]"></div>
    <div class="absolute bottom-10 right-0 w-72 h-72 bg-accent-1 rounded-full opacity-40 blur-[100px]"></div>
	
  <div class="absolute top-20 right-20 w-32 h-32 border border-main-1 rounded-full opacity-40"></div>
  <div class="absolute bottom-20 left-20 w-40 h-40 border border-accent-1 rounded-full opacity-40"></div>
  <div class="absolute top-1/2 left-1/3 w-20 h-20 border border-main-1 rounded-full opacity-20"></div>
  </div>

  {/* コンテンツ幅を最大1440pxに制限し、中央寄せ */}
  <div class="relative z-10 w-full max-w-[1440px] flex flex-col md:flex-row items-center gap-12">
    
    <div class="flex-1 space-y-6">
      <h1 class="text-3xl md:text-5xl leading-tight" set:html={heroTitle} />
      <p class="font-serif text-accent-1 text-xl font-bold">{heroSub}</p>
      <div class="text-black-1 leading-relaxed" set:html={heroDescription} />
      <a href="/contact" class="inline-block bg-main-1 text-white-1 px-10 py-4 rounded-full shadow-lg transition-transform hover:scale-105">
        {buttonText}
      </a>
    </div>

    <div class="flex-1 w-full">
      <Image 
        src={heroImage} 
        alt="占い風景" 
        class="rounded-3xl shadow-xl w-full h-auto object-cover max-h-[500px]" 
      />
    </div>
  </div>
</section>