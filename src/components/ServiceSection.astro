---
import { getEntry } from 'astro:content';
import SectionContainer from './SectionContainer.astro';
import { Clock, Sparkles, Heart, CircleCheck } from 'lucide-astro'; 

const serviceData = await getEntry('home', 'service');
if (!serviceData) throw new Error("service.jsonが見つかりません");

const { title, description, items } = serviceData.data;
---

<section class="bg-white-1 py-80">
  <SectionContainer>
    <div class="mb-16 space-y-4">
      <h2 class="text-4xl md:text-5xl font-serif text-main-1 text-center">{title}</h2>
      <p class="text-xl text-black-1/60 max-w-xl mx-auto text-left">{description}</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {items.map((item, index) => (
        <div class="group p-8 border border-main-1/10 rounded-2xl bg-white shadow-sm hover:shadow-xl hover:border-main-1/30 transition-all duration-500 flex flex-col relative overflow-hidden">
          
          <div class="absolute top-0 right-0 p-4 opacity-20">
            <Sparkles class="w-8 h-8 text-main-1" />
          </div>

          <div class="mb-8">
            <h3 class="text-2xl font-serif font-bold text-main-1 mb-2 group-hover:text-main-1/80 transition-colors">
              {item.name}
            </h3>
            <div class="flex items-baseline gap-2 text-black-1/80">
              <Clock class="w-4 h-4" />
              <span class="text-xl font-bold">{item.time}</span>
              <span class="text-base">/ {item.price}</span>
            </div>
          </div>
          
          <p class="text-black-1/70 mb-8 flex-grow leading-relaxed">
            {item.description}
          </p>
          
          <ul class="space-y-4 mt-auto border-t border-main-1/5 pt-8">
            {item.features.map((feature) => (
              <li class="text-base flex items-center text-black-1/70">
                <CircleCheck class="w-4 h-4 mr-3 text-main-1/40" />
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </SectionContainer>
</section>