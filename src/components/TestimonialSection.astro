---
import { getEntry } from 'astro:content';
import SectionContainer from './SectionContainer.astro';

const data = await getEntry('home', 'testimonials');
if (!data) throw new Error("testimonials.jsonが見つかりません");

const { title, reviews } = data.data as {
  title: string;
  reviews: { name: string; topic: string; comment: string }[];
};
---

<section class="py-24 bg-white-1">
  <SectionContainer>
    <h2 class="text-3xl font-serif text-main-1 text-center mb-16">{title}</h2>
    
    <div class="grid md:grid-cols-2 gap-8">
      {reviews.map((item) => (
        <div class="p-8 bg-base-1/20 border-l-4 border-main-1 rounded-r-2xl">
          <p class="text-base italic leading-relaxed text-black-1/80 mb-6">
            "{item.comment}"
          </p>
          <div class="border-t border-base-1 pt-4">
            <p class="text-base font-bold text-main-1">{item.name}</p>
            <p class="text-sm text-black-1/60">{item.topic}</p>
          </div>
        </div>
      ))}
    </div>
  </SectionContainer>
</section>