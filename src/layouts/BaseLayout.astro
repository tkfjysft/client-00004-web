---
import { NAV_ITEMS, SITE_TITLE } from '../data/site';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';


interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | {SITE_TITLE}</title>
  </head>
  <body class="min-h-screen bg-base-1">
    <Header />
      <nav class="container mx-auto px-6 py-4 flex items-center justify-between">
        <div class="text-xl font-serif font-bold text-main-1">{SITE_TITLE}</div>
        
        {/* PC用メニュー */}
        <ul class="hidden md:flex gap-8">
          {NAV_ITEMS.map((item) => (
            <li><a href={item.url} class="text-black-1 hover:text-main-1 transition-colors">{item.text}</a></li>
          ))}
        </ul>

        {/* ハンバーガーボタン */}
        <button id="menu-btn" class="md:hidden p-2 text-main-1">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
      </nav>


    <main class="pt-20">
      <slot />
    </main>

	<Footer />

    {/* 開閉制御用のスクリプト */}
    <script>
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>